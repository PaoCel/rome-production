rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function email() {
      return request.auth.token.email.lower();
    }

    function isOwner() {
      return isSignedIn()
        && email() in [
          'paolocelestini23@gmail.com',
          'spaminutili24@gmail.com',
          'mirko.valle20@gmail.com'
        ];
    }

    function inviteQuery(projectId, section) {
      return exists(/databases/$(database)/documents/projects/$(projectId)/invites/$(email()))
        && get(/databases/$(database)/documents/projects/$(projectId)/invites/$(email())).data.status == 'active'
        && section in get(/databases/$(database)/documents/projects/$(projectId)/invites/$(email())).data.sections;
    }

    function sectionForCollection(collectionName) {
      return collectionName in ['tasks']
        ? 'tasks'
        : collectionName in ['budgetItems']
        ? 'budget'
        : collectionName in ['invoices']
        ? 'invoices'
        : collectionName in ['locationRequirements', 'locationOptions']
        ? 'locations'
        : collectionName in ['castRoles', 'castingOptions']
        ? 'casting'
        : collectionName in ['crewRequirements', 'crewOptions']
        ? 'crew'
        : collectionName in ['propItems', 'propOptions']
        ? 'props'
        : collectionName in ['productionOptions']
        ? 'production'
        : collectionName in ['contacts']
        ? 'contacts'
        : collectionName in ['risks', 'decisions']
        ? 'risks'
        : '';
    }

    function sectionForRelatedType(relatedType) {
      return relatedType in ['task']
        ? 'tasks'
        : relatedType in ['invoice']
        ? 'invoices'
        : relatedType in ['locationRequirement', 'locationOption']
        ? 'locations'
        : relatedType in ['castRole', 'castingOption']
        ? 'casting'
        : relatedType in ['crewRequirement', 'crewOption']
        ? 'crew'
        : relatedType in ['propItem', 'propOption']
        ? 'props'
        : relatedType in ['productionOption']
        ? 'production'
        : relatedType in ['contact']
        ? 'contacts'
        : relatedType in ['risk', 'decision']
        ? 'risks'
        : '';
    }

    function canReadCollection(projectId, collectionName) {
      return isOwner()
        || (isSignedIn()
          && sectionForCollection(collectionName) != ''
          && inviteQuery(projectId, sectionForCollection(collectionName)));
    }

    function canAccessRelated(projectId, data) {
      return isOwner()
        || (isSignedIn()
          && sectionForRelatedType(data.relatedType) != ''
          && inviteQuery(projectId, sectionForRelatedType(data.relatedType)));
    }

    function canAccessTask(projectId, data) {
      return canReadCollection(projectId, 'tasks')
        || canAccessRelated(projectId, data);
    }

    function sectionForBudgetSource(sourceType) {
      return sourceType in ['location', 'locationOption']
        ? 'locations'
        : sourceType in ['castingCandidate', 'castingOption']
        ? 'casting'
        : sourceType in ['crewOption']
        ? 'crew'
        : sourceType in ['propOption']
        ? 'props'
        : sourceType in ['productionOption']
        ? 'production'
        : '';
    }

    function canAccessBudgetItem(projectId, data) {
      return canReadCollection(projectId, 'budgetItems')
        || (isSignedIn()
          && sectionForBudgetSource(data.sourceType) != ''
          && inviteQuery(projectId, sectionForBudgetSource(data.sourceType)));
    }

    match /projects/{projectId} {
      allow read, write: if isOwner();

      match /invites/{inviteId} {
        allow get, list: if isOwner() || (isSignedIn() && inviteId == email());
        allow create, update, delete: if isOwner();
      }

      match /media/{docId} {
        allow read, delete: if canAccessRelated(projectId, resource.data);
        allow create: if canAccessRelated(projectId, request.resource.data);
        allow update: if canAccessRelated(projectId, resource.data)
          && canAccessRelated(projectId, request.resource.data);
      }

      match /comments/{docId} {
        allow read, delete: if canAccessRelated(projectId, resource.data);
        allow create: if canAccessRelated(projectId, request.resource.data);
        allow update: if canAccessRelated(projectId, resource.data)
          && canAccessRelated(projectId, request.resource.data);
      }

      match /tasks/{docId} {
        allow read, delete: if canAccessTask(projectId, resource.data);
        allow create: if canAccessTask(projectId, request.resource.data);
        allow update: if canAccessTask(projectId, resource.data)
          && canAccessTask(projectId, request.resource.data);
      }

      match /budgetItems/{docId} {
        allow read, delete: if canAccessBudgetItem(projectId, resource.data);
        allow create: if canAccessBudgetItem(projectId, request.resource.data);
        allow update: if canAccessBudgetItem(projectId, resource.data)
          && canAccessBudgetItem(projectId, request.resource.data);
      }

      // Every casting viewer can cast exactly one like/dislike per profile.
      // The deterministic id prevents duplicate votes from the same account.
      match /castingVotes/{voteId} {
        allow read: if canReadCollection(projectId, 'castingOptions');
        allow create: if canReadCollection(projectId, 'castingOptions')
          && voteId == request.resource.data.optionId + '--' + request.auth.uid
          && exists(/databases/$(database)/documents/projects/$(projectId)/castingOptions/$(request.resource.data.optionId))
          && request.resource.data.voterId == request.auth.uid
          && request.resource.data.value in ['like', 'dislike']
          && request.resource.data.keys().hasOnly([
            'optionId', 'voterId', 'value', 'updatedAt'
          ]);
        allow update: if canReadCollection(projectId, 'castingOptions')
          && voteId == request.resource.data.optionId + '--' + request.auth.uid
          && exists(/databases/$(database)/documents/projects/$(projectId)/castingOptions/$(request.resource.data.optionId))
          && resource.data.optionId == request.resource.data.optionId
          && resource.data.voterId == request.auth.uid
          && request.resource.data.voterId == request.auth.uid
          && request.resource.data.value in ['like', 'dislike']
          && request.resource.data.keys().hasOnly([
            'optionId', 'voterId', 'value', 'updatedAt'
          ]);
        allow delete: if canReadCollection(projectId, 'castingOptions');
      }

      match /{subCollection}/{docId} {
        allow read: if canReadCollection(projectId, subCollection);
        allow create, update, delete: if canReadCollection(projectId, subCollection);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
